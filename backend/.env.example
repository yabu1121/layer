# backend (.env) — 値を埋めて .env としてコピー。Git には上げない。
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/layer?sslmode=disable
# Google OAuth クライアント ID（ID トークンの aud 検証に使用）。
GOOGLE_OAUTH_CLIENT_ID=
# CORS 許可オリジン（カンマ区切り）。未設定なら開発用に全許可（"*"）。
# 本番では必ずフロント/モバイルのオリジンを設定する。
ALLOWED_ORIGINS=
# レート制限（IP 単位、超過で 429）。未設定なら既定値を使用。
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40
# サインインは総当たり対策で別途厳しめ。
AUTH_RATE_LIMIT_RPS=1
AUTH_RATE_LIMIT_BURST=5
# 画像アップロード（Cloudflare R2、S3 互換）。未設定なら presign API は 503。
# R2 バケット作成後にアクセスキーを発行して設定する（公開取得 URL は PUBLIC_BASE_URL）。
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
